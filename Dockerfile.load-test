# ── Build stage ─────────────────────────────────────────────────────────────────
FROM golang:1.24-alpine AS builder

RUN apk add --no-cache git gcc musl-dev

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -trimpath -o /bin/load-test ./cmd/load-test

# ── Runtime stage ────────────────────────────────────────────────────────────────
FROM scratch

COPY --from=builder /bin/load-test /load-test

ENTRYPOINT ["/load-test"]
