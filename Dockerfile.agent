FROM golang:1.24-bookworm AS build

RUN apt-get update && apt-get install -y --no-install-recommends \
    libpcap-dev \
    ca-certificates \
 && rm -rf /var/lib/apt/lists/*

WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download

COPY . .

# config.json is embedded at compile time via //go:embed — no runtime file needed.
RUN CGO_ENABLED=1 GOOS=linux GOARCH=amd64 go build -o /out/agent ./cmd/agent


FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    libpcap0.8 \
    ca-certificates \
 && rm -rf /var/lib/apt/lists/*

COPY --from=build /out/agent /agent

ENTRYPOINT ["/agent"]

