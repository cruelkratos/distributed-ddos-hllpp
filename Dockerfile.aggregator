FROM golang:1.24-bookworm AS build

WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download

COPY . .

# config.json is embedded at compile time via //go:embed — no runtime file needed.
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -trimpath -ldflags="-s -w" -o /out/aggregator ./cmd/aggregator

FROM gcr.io/distroless/static-debian12:nonroot

COPY --from=build /out/aggregator /aggregator

EXPOSE 8080 9090

ENTRYPOINT ["/aggregator"]

